<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="@dimen/padding_grande"
    android:background="@color/fundoTela"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/padding_grande">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/padding_medio">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_alarm"
            android:tint="@color/verdePrimario"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/verdePrimario"
            android:textSize="@dimen/texto_titulo"
            android:textStyle="bold"/>

    </LinearLayout>

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_grande"
        android:gravity="center"
        android:text="@string/titulo_login"
        android:textColor="@color/textoSecundario"
        android:textSize="@dimen/texto_normal" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_medio"
        android:ems="10"
        android:hint="@string/hint_email"
        android:inputType="textEmailAddress"
        android:padding="@dimen/padding_medio"
        android:textColor="@color/textoSecundario"
        android:textColorHint="@color/textoSecundario"
        android:textSize="@dimen/texto_normal" />

    <EditText
        android:id="@+id/etSenha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_grande"
        android:ems="10"
        android:hint="@string/hint_senha"
        android:inputType="textPassword"
        android:padding="@dimen/padding_medio"
        android:textColor="@color/textoSecundario"
        android:textColorHint="@color/textoSecundario"
        android:textSize="@dimen/texto_normal" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_medio"
        android:backgroundTint="@color/verdePrimario"
        android:text="@string/btn_entrar"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/tvCadastreSe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="@dimen/padding_pequeno"
        android:text="@string/link_cadastro"
        android:textColor="@color/verdePrimario"
        android:textSize="@dimen/texto_pequeno" />
</LinearLayout>