<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundoTela"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/padding_grande">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_medio"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_alarm"
            app:tint="@color/azulPrimario" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/azulPrimario"
            android:textSize="@dimen/texto_titulo"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_grande"
        android:gravity="center"
        android:text="@string/titulo_login"
        android:textColor="@color/textoSecundario"
        android:textSize="@dimen/texto_normal"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="@dimen/padding_medio"
        android:background="@android:drawable/edit_text"
        android:gravity="center_vertical"
        android:hint="@string/hint_email"
        android:inputType="textEmailAddress"
        android:minHeight="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/textoEscuro"
        android:textColorHint="@color/textoHint"
        android:textSize="@dimen/texto_normal" />

    <EditText
        android:id="@+id/etSenha"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="@dimen/padding_grande"
        android:background="@android:drawable/edit_text"
        android:gravity="center_vertical"
        android:hint="@string/hint_senha"
        android:inputType="textPassword"
        android:minHeight="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/textoEscuro"
        android:textColorHint="@color/textoHint"
        android:textSize="@dimen/texto_normal" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="@dimen/padding_medio"
        android:backgroundTint="@color/azulPrimario"
        android:minHeight="56dp"
        android:text="@string/btn_entrar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/texto_normal"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCadastreSe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minHeight="48dp"
        android:padding="12dp"
        android:text="@string/link_cadastro"
        android:textColor="@color/azulPrimario"
        android:textSize="@dimen/texto_pequeno"
        android:textStyle="bold" />
</LinearLayout>