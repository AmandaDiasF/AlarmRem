<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundoTela">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Novo Alarme"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/textoEscuro"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etNomeRemedio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do remédio"
            android:textColorHint="@color/black"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etDescricao"
            android:textColorHint="@color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descrição / como tomar"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="16dp" />
        <!-- INÍCIO: bloco de repetição por dias da semana -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repetir nos dias:"
            android:textStyle="bold"
            android:textColor="@color/textoEscuro"
            android:layout_marginBottom="8dp" />

        <!-- Container geral dos checkboxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Primeira linha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbDom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dom"
                    android:textColor="@color/textoEscuro" />

                <CheckBox
                    android:id="@+id/cbSeg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Seg"
                    android:textColor="@color/textoEscuro" />

                <CheckBox
                    android:id="@+id/cbTer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ter"
                    android:textColor="@color/textoEscuro" />

                <CheckBox
                    android:id="@+id/cbQua"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Qua"
                    android:textColor="@color/textoEscuro" />
            </LinearLayout>

            <!-- Segunda linha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/cbQui"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Qui"
                    android:textColor="@color/textoEscuro" />

                <CheckBox
                    android:id="@+id/cbSex"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sex"
                    android:textColor="@color/textoEscuro" />

                <CheckBox
                    android:id="@+id/cbSab"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sáb"
                    android:textColor="@color/textoEscuro" />

                <CheckBox
                    android:id="@+id/cbTodos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Todos"
                    android:textColor="@color/textoEscuro" />
            </LinearLayout>

        </LinearLayout>
        <!-- FIM: bloco de repetição por dias da semana -->

        <Button
            android:id="@+id/btnSelecionarHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecionar hora"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/verdeClaro"
            android:textColor="@color/textoEscuro" />


        <Button
            android:id="@+id/btnAdicionarFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adicionar foto do remédio"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/verdeClaro"
            android:textColor="@color/textoEscuro" />

        <ImageView
            android:id="@+id/imgMedicamento"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:contentDescription="Foto do medicamento"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <Button
            android:id="@+id/btnSalvarAlarme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar"
            android:backgroundTint="@color/verdePrimario"
            android:textColor="@color/white" />
    </LinearLayout>

</ScrollView>