<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/fundoTela">

    <ImageView
        android:id="@+id/imgFotoAlarme"
        android:layout_width="270dp"
        android:layout_height="265dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <TextView
        android:id="@+id/tvTituloAlarme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Hora do remédio"
        android:textColor="@color/azulPrimario"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDescricaoAlarme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Descrição"
        android:textColor="@color/textoEscuro"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnAdiarAlarme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/alerta"
        android:text="Adiar 5 minutos"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/btnOkAlarme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/azulPrimario"
        android:text="OK"
        android:textColor="@color/white" />

</LinearLayout>